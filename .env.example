# ── Audit output ──
CHROME_PATH=/usr/bin/chromium
AGENT_BROWSER_PATH=/usr/local/bin/agent-browser

# ── Web server ──
PORT=8080
MAX_CONCURRENT_AUDITS=2

# ── Optional: Lighthouse override ──
# LIGHTHOUSE_PATH=/usr/local/bin/lighthouse

# ── Optional: Shopify AI Toolkit Integration ─────────────
# Enables deep product inspection (GTIN, exact description length) 
# via Admin API without relying solely on web scraping.
SHOPIFY_SHOP_DOMAIN=store.myshopify.com
SHOPIFY_ACCESS_TOKEN=shpat_1234567890abcdef
